# Cloudways Application SSH credentials
# Find these in: Cloudways Dashboard → Your Server → Application → Access Details

CLOUDWAYS_SSH_HOST=your.server.public.ip
CLOUDWAYS_SSH_USER=your_application_username
CLOUDWAYS_SSH_PORT=22
CLOUDWAYS_SSH_KEY=~/.ssh/id_rsa

# Remote path (Cloudways WordPress root)
CLOUDWAYS_DEPLOY_PATH=~/public_html/

# Set to "full" to upload entire site, or "content" for index.html + assets only
DEPLOY_MODE=content
